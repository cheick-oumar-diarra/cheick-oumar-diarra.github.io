@article{PETIT2026108262,
title = {Thermal conductivities of amorphous SiO2 films by approach-to-equilibrium molecular dynamics},
journal = {Solid State Sciences},
volume = {175},
pages = {108262},
year = {2026},
issn = {1293-2558},
doi = {https://doi.org/10.1016/j.solidstatesciences.2026.108262},
url = {https://www.sciencedirect.com/science/article/pii/S1293255826000543},
author = {Louis Petit and Cheick O. Diarra and Achille Lambrecht and Ibrahim Bel-Hadj and Mauro Boero and Evelyne Martin},
keywords = {Thermal conductivity, Film, Amorphous SiO},
abstract = {The thermal conductivity of stand-alone amorphous SiO2 films is calculated both in and cross plane. In both cases, the approach-to-equilibrium molecular dynamics (AEMD) method is employed, showing how the method can be extended to calculate the cross-plane thermal conductivity. The study is conducted within the first-principles molecular dynamics framework. We ascertain that the thermal conductivity in the plane remains unaffected by the presence of free surfaces. Remarkably, even for a thickness of 2 nm, the thermal conductivity is found to be equal to (1.3 ± 0.1) W K−1 m−1, which is in accordance with the measured macroscopic value. With regard to cross-plane thermal conductivity, the value for a film with thickness d is equivalent to that obtained by AEMD in the case of a bulk with a periodicity of 2d. The cross-plane thermal conductivity is shown to decrease for thicknesses below 3 nm.}
}

@article{PETIT2026108325,
title = {On the crystallization tendency of amorphous Sb2S3 under pressure: A first-principles molecular dynamics study},
journal = {Solid State Sciences},
volume = {177},
pages = {108325},
year = {2026},
issn = {1293-2558},
doi = {https://doi.org/10.1016/j.solidstatesciences.2026.108325},
url = {https://www.sciencedirect.com/science/article/pii/S1293255826001184},
author = {Louis Petit and Julien Taillieu and Carlo Massobrio and Cheick O. Diarra and Achille Lambrecht and Mauro Boero and Evelyne Martin},
keywords = {Atomic scale modeling, First-principles molecular dynamics, Amorphous systems, Phase-change materials, Amorphous to crystal transitions},
abstract = {Amorphous Sb2S3 has been studied by first-principles molecular dynamics (FPMD) at T = 300 K by considering two distinct thermodynamical conditions: (a) a vanishing pressure obtained by optimizing the size of the periodic cell and (b) a finite pressure of up to 5 GPa. To this end, both the constant volume, constant temperature (NVT) and the constant pressure, constant temperature (NPT) molecular dynamics methodologies have been used. At vanishing pressure, our results for the partial pair correlation functions are in broad agreement with previous FPMD data obtained by using a different theoretical scheme based on hybrid exchange–correlation functionals. Conversely, application of a finite pressure leads to marked changes of the network topologies for nearest and next-nearest neighbor distances. Such modifications are reminiscent of an incipient transition toward a crystalline order, indicating that application of pressure can play a crucial role in impacting the amorphous to crystal transformations inherent in this phase-change material.}
}

@Article{D3CP00533J,
author ="Diarra, Cheick Oumar and Boero, Mauro and Steveler, Emilie and Heiser, Thomas and Martin, Evelyne",
title  ="Exciton diffusion in poly(3-hexylthiophene) by first-principles molecular dynamics",
journal  ="Phys. Chem. Chem. Phys.",
year  ="2023",
volume  ="25",
issue  ="22",
pages  ="15539-15546",
publisher  ="The Royal Society of Chemistry",
doi  ="10.1039/D3CP00533J",
url  ="http://dx.doi.org/10.1039/D3CP00533J",
abstract  ="Poly(3-hexylthiophene) (P3HT) is a polymer used in organic solar cells as a light absorber and an electron donor. Photogenerated excitons diffuse and dissociate into free charge carriers provided they reach the absorber boundaries. The device efficiency is therefore dependent on the exciton diffusion. Although measurements can be performed for example by time-resolved photoluminescence{,} a quantitative modeling is highly desirable to get an insight into the relationship between the atomic structure at finite temperature and the diffusion coefficient of the exciton. This is the objective of the present work{,} achieved by resorting to first-principles molecular dynamics in combination with the restricted open-shell approach to model the singlet excited state. The maximally localized Wannier functions and their centers are used to monitor and localize the electron and the hole along the dynamics. The resulting diffusion coefficient is in close agreement with available measurements."}

